# Frontend environment variables — LOCAL DEV ONLY.
# When running via Docker Compose, this file is NOT used.
# Never commit .env — it's in .gitignore.
#
# ⚠️  DO NOT put API keys here.
#     VITE_* variables are baked into the JS bundle at build time and are
#     fully visible to anyone in a browser. All AI inference is server-side.
#
# Backend URL for local Vite dev server proxy (default: http://localhost:8000)
VITE_API_URL=http://localhost:8000
