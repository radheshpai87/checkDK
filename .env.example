# checkDK — root environment variables
# Copy this file:  cp .env.example .env
# Then fill in your actual values.  Never commit .env

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Mistral (primary) — https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your_mistral_api_key_here

# Groq (fallback, fast + free) — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Which provider to use first: mistral | groq
# If the chosen provider's key is missing or the call fails, the other is tried.
CHECKDK_AI_PROVIDER=mistral
CHECKDK_AI_ENABLED=true

# ── Backend ───────────────────────────────────────────────────────────────────
# Port the FastAPI server listens on inside Docker (default: 8000)
# BACKEND_PORT=8000

# ── CLI (not used by Docker — set in cli/.env or ~/.checkdk/.env) ─────────────
# CHECKDK_API_URL=http://localhost:8000
