# checkDK — root environment variables
# Copy this file:  cp .env.example .env
# Then fill in your actual values.  Never commit .env

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Mistral (primary) — https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your_mistral_api_key_here

# Groq (fallback, fast + free) — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Which provider to use first: mistral | groq
CHECKDK_AI_PROVIDER=mistral
CHECKDK_AI_ENABLED=true

# ── Auth / OAuth ───────────────────────────────────────────────────────────────
# GitHub OAuth app — https://github.com/settings/developers
GITHUB_CLIENT_ID=your_github_client_id_here
GITHUB_CLIENT_SECRET=your_github_client_secret_here

# Google OAuth app — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here

# JWT signing secret — generate with: openssl rand -hex 32
JWT_SECRET=dev-secret-change-in-production

# ── URLs (Docker Compose — nginx on :3000 proxies /api/* → backend:8000) ──────
APP_BASE_URL=http://localhost:3000
OAUTH_CALLBACK_BASE=http://localhost:3000/api
FRONTEND_URL=http://localhost:3000

# ── DynamoDB ───────────────────────────────────────────────────────────────────
DYNAMODB_REGION=us-east-1
DYNAMODB_USERS_TABLE=checkdk_users
DYNAMODB_HISTORY_TABLE=checkdk_history

# ── Backend ───────────────────────────────────────────────────────────────────
# CORS_ORIGINS=http://localhost:3000
# BACKEND_PORT=8000
