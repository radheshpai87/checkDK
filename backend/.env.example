# checkDK backend environment variables — STANDALONE DEV ONLY.
# When running via Docker Compose, use the ROOT .env.example instead.
# Docker Compose injects env vars from the root .env directly into the container.
# Copy this file:  cp .env.example .env   (inside the backend/ directory)

# ── AI / LLM ──────────────────────────────────────────────────────────────────
# Mistral (primary) — https://console.mistral.ai/api-keys/
MISTRAL_API_KEY=your_mistral_api_key_here

# Groq (fallback, fast + free) — https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Which provider to use first: mistral | groq
CHECKDK_AI_PROVIDER=mistral
CHECKDK_AI_ENABLED=true

# Optional: Disable AI entirely (rule-based analysis only)
# CHECKDK_AI_ENABLED=false
